# ============================================
# FoodmoleGPT — Whitelist .gitignore
# Only tracked: CPT_dataset, SFT_dataset, RAG, LLM_BO
# ============================================

# Ignore everything at root level
/*

# ---- Root files to track ----
!/.gitignore
!/README.md
!/TRAINING_REPORT.md

# ---- Directories to track ----
!/CPT_dataset/
!/SFT_dataset/
!/RAG/
!/LLM_BO/

# ============================================
# Global exclusions (apply within all tracked dirs)
# ============================================

# OS / IDE / Python artifacts
**/.DS_Store
**/__pycache__/
**/.ipynb_checkpoints/
**/.claude/
**/*.pyc
**/*.pyo

# Secrets & credentials
**/.env
**/config.py

# Large data files (never commit)
**/*.jsonl
**/*.xml
**/*.gz
**/*.zip
**/*.tar
**/*.log
**/nohup.out

# ============================================
# CPT_dataset — directory-specific exclusions
# ============================================

# PubMed raw data directory (189K+ XML files + large processed data)
CPT_dataset/essay/PubMed/data/
CPT_dataset/essay/PubMed/logs/
